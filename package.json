{
	"name": "@atom-forge/laminar",
	"version": "0.2.0",
	"description": "Lightweight, type-safe layered architecture and dependency injection system",
	"keywords": [
		"laminar",
		"di",
		"dependency-injection",
		"layer",
		"typescript"
	],
	"author": {
		"name": "Gergely Laborci",
		"url": "https://github.com/laborci"
	},
	"license": "MIT",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/atom-forge/laminar.git"
	},
	"files": [
		"dist",
		"docs",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "bun run build",
		"release": "npm publish --access public",
		"pub-check": "bun run scripts/pub-check.ts",
		"pub": "bun run scripts/pub.ts"
	},
	"devDependencies": {
		"@types/node": "^25.3.1",
		"tsup": "^8.5.1",
		"typescript": "^5.0.0"
	}
}
